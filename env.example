# ─── Required ───────────────────────────────────────────────────────────────
BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_IDS=123456789,987654321

# ─── Optional ────────────────────────────────────────────────────────────────
# Your bot's username (without @) — used for referral links
BOT_USERNAME=myshopbot

# Telegram channel users must join before using the bot
# Format: @channelname  OR  -100xxxxxxxxxx (numeric ID for private channels)
REQUIRED_CHANNEL=@mychannel

# Wallet credit given to referrer when new user joins via their link
REFERRAL_BONUS=10.0

# Currency symbol displayed in UI
CURRENCY_SYMBOL=₹

# SQLite database file path (Railway uses /app/data/ for persistent volumes)
DB_PATH=shop.db
